# PatchIQ Development Environment
# Auto-generated by: ./scripts/dev-env.sh <username>
# Copy to .env and customize, or just run: make dev-env
#
# See CLAUDE.md "Shared Dev Server" section for per-user port offsets.

# ── Docker Compose isolation ────────────────────────────────
COMPOSE_PROJECT_NAME=patchiq-<username>

# ── Infrastructure ports (docker-compose.dev.yml) ───────────
PG_PORT=5432
VALKEY_PORT=6379
ZITADEL_PORT=8085
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
GRAFANA_PORT=3000
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318

# ── Per-user database names ─────────────────────────────────
DB_NAME_SERVER=patchiq_dev_<username>
DB_NAME_HUB=patchiq_hub_dev_<username>

# ── Server (PATCHIQ_ prefix for koanf config overlay) ──────
PATCHIQ_SERVER_HTTP_PORT=8080
PATCHIQ_SERVER_GRPC_PORT=50051
PATCHIQ_DATABASE_URL=postgres://patchiq:patchiq_dev@localhost:5432/patchiq_dev_<username>?sslmode=disable
PATCHIQ_WATERMILL_POSTGRES_URL=postgres://patchiq:patchiq_dev@localhost:5432/patchiq_dev_<username>?sslmode=disable
PATCHIQ_VALKEY_URL=redis://localhost:6379
PATCHIQ_OTEL_ENDPOINT=localhost:4317
PATCHIQ_IAM_ZITADEL_DOMAIN=localhost:8085
PATCHIQ_IAM_ZITADEL_CLIENT_ID=
PATCHIQ_IAM_ZITADEL_CLIENT_SECRET=
PATCHIQ_IAM_ZITADEL_SERVICE_ACCOUNT_KEY=
PATCHIQ_IAM_ZITADEL_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback
PATCHIQ_IAM_SESSION_POST_LOGIN_URL=http://localhost:3001/
PATCHIQ_SERVER_CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# ── Hub (PATCHIQ_HUB_ prefix for koanf config overlay) ─────
PATCHIQ_HUB_HUB_HTTP_PORT=8082
PATCHIQ_HUB_DATABASE_URL=postgres://patchiq:patchiq_dev@localhost:5432/patchiq_hub_dev_<username>?sslmode=disable
PATCHIQ_HUB_WATERMILL_POSTGRES_URL=postgres://patchiq:patchiq_dev@localhost:5432/patchiq_hub_dev_<username>?sslmode=disable
PATCHIQ_HUB_HUB_MINIO_ACCESS_KEY=minioadmin
PATCHIQ_HUB_HUB_MINIO_SECRET_KEY=minioadmin
PATCHIQ_HUB_IAM_ZITADEL_DOMAIN=localhost:8085
PATCHIQ_HUB_IAM_ZITADEL_CLIENT_ID=
PATCHIQ_HUB_IAM_ZITADEL_SERVICE_ACCOUNT_KEY=
PATCHIQ_HUB_IAM_ZITADEL_REDIRECT_URI=http://localhost:8082/api/v1/auth/callback
PATCHIQ_HUB_IAM_SESSION_POST_LOGIN_URL=http://localhost:3002/

# ── Agent (PATCHIQ_AGENT_ prefix) ──────────────────────────
PATCHIQ_AGENT_HTTP_ADDR=127.0.0.1:8090
PATCHIQ_AGENT_SERVER_ADDRESS=localhost:50051

# ── Frontend (Vite) ────────────────────────────────────────
VITE_SERVER_PORT=3001
VITE_HUB_PORT=3002
VITE_AGENT_PORT=3003
VITE_API_SERVER_URL=http://localhost:8080
VITE_API_HUB_URL=http://localhost:8082
VITE_API_AGENT_URL=http://localhost:8090

# ── Seed / migrate helpers ──────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGUSER=patchiq
PGPASSWORD=patchiq_dev
